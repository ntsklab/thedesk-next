{
	"private": true,
	"main": "main-build/index.js",
	"name": "thedesk-next-hl",
	"author": {
		"name": "cutls",
		"url": "https://github.com/cutls/thedesk-next"
	},
	"contributors": [
		{
			"name": "ntsklab",
			"url": "https://github.com/ntsklab/thedesk-next"
		}
	],
	"version": "25.4.0-hollo1",
	"codename": "Aiko",
	"homepage": "https://github.com/ntsklab/thedesk-next",
	"packageManager": "pnpm@10.5.2",
	"scripts": {
		"postinstall": "sh scripts/apply-patches.sh",
		"clean": "rimraf dist main renderer/out renderer/.next",
		"dev": "npm run build-electron && concurrently -n \"NEXT,ELECTRON\" -c \"yellow,blue\" --kill-others \"next dev renderer\" \"electron .\"",
		"build-renderer": "next build renderer",
		"build-electron": "tsc -p electron-src",
		"build": "npm run thirdparty && npm run build-renderer && npm run build-electron && node scripts/toRelativePath.js",
		"pack:mac": "electron-builder --mac --universal",
		"pack:mas": "sh build/mas.delete.sh && electron-builder --mac --universal --config electron-builder.mas.json",
		"pack:linux": "electron-builder --linux --x64",
		"pack:win": "electron-builder --windows --x64",
		"pack:winArm64": "electron-builder --windows --arm64",
		"pack:appx": "electron-builder --windows --x64 --config electron-builder.appx.json",
		"dist": "npm run build && electron-builder",
		"type-check": "tsc -p ./renderer/tsconfig.json && tsc -p ./electron-src/tsconfig.json",
		"lint:fix": "npx @biomejs/biome check --write ./",
		"thirdparty": "license-checker --production --json > thirdparty.json && node scripts/thirdparty.js"
	},
	"dependencies": {
		"@cutls/megalodon": "7.2.4",
		"@emoji-mart/react": "^1.1.1",
		"@rsuite/icons": "^1.4.0",
		"cheerio": "1.1.2",
		"dayjs": "^1.11.18",
		"electron-dl-manager": "^4.2.3",
		"electron-is-dev": "^3.0.1",
		"electron-native-auth": "^0.2.0",
		"electron-next": "^3.1.5",
		"electron-serve": "^3.0.0",
		"electron-window-state": "^5.0.3",
		"emoji-mart": "^5.6.0",
		"font-list": "^2.0.1",
		"next": "^14.2.3",
		"ntp-client": "^0.5.3",
		"parse-link-header": "^2.0.0",
		"react": "18.2.0",
		"react-blurhash": "^0.3.0",
		"react-dom": "18.2.0",
		"react-draggable": "^4.5.0",
		"react-icons": "5.4.0",
		"react-intl": "^7.1.13",
		"react-resizable": "^3.0.5",
		"react-viewer": "^3.2.2",
		"react-virtuoso": "4.14.1",
		"rsuite": "5.83.3",
		"sanitize-html": "^2.17.0",
		"sass": "^1.93.2",
		"semver": "^7.7.3",
		"superagent": "^10.0.3",
		"tar": "^7.5.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.6",
		"@electron/notarize": "^3.1.1",
		"@formatjs/intl-displaynames": "^6.8.13",
		"@types/node": "^14.18.63",
		"@types/ntp-client": "^0.5.0",
		"@types/react": "^16.14.52",
		"@types/react-dom": "^16.9.24",
		"@types/react-resizable": "^3.0.8",
		"@types/sanitize-html": "^2.11.0",
		"@types/semver": "^7.7.1",
		"@types/superagent": "^8.1.9",
		"concurrently": "^9.2.1",
		"electron": "37",
		"electron-builder": "26.8.1",
		"license-checker": "^25.0.1",
		"rimraf": "^6.0.1",
		"typescript": "^5.9.3"
	},
	"resolutions": {
		"react": "18.2.0",
		"react-dom": "18.2.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"electron",
			"electron-native-auth",
			"electron-winstaller"
		]
	}
}
